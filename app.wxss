page {
  min-height: 100vh;
  background: #f7f1e4;
  color: #314d37;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
}

.section {
  margin-top: 32rpx;
}

.eyebrow {
  color: #6d7e63;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 6rpx;
}

.title {
  margin-top: 12rpx;
  color: #314d37;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.25;
}

.body {
  color: #596955;
  font-size: 28rpx;
  line-height: 1.8;
}

.card {
  border: 1rpx solid #d7d8c9;
  border-radius: 16rpx;
  background: #fbf8ef;
  box-shadow: 0 16rpx 40rpx rgba(95, 112, 82, 0.1);
}

.primary-button {
  border-radius: 999rpx;
  background: #587a5b;
  color: #fff;
}

.muted {
  color: #7b8675;
}
