<view class="page home-page">
  <image class="home-poster" src="/assets/home-poster.jpg" mode="aspectFill" />

  <view class="activity-feed">
    <view wx:if="{{loadingActivities}}" class="body state-text">正在读取服务器数据...</view>
    <view wx:elif="{{activityErrorMessage}}" class="body state-text error-text">{{activityErrorMessage}}</view>
    <block wx:else>
      <block wx:for="{{activities}}" wx:key="id" wx:for-item="activity">
        <view class="activity-card card" data-id="{{activity.id}}" bindtap="goActivityDetail">
          <image class="activity-cover" src="{{activity.coverImage}}" mode="aspectFill" />
          <view class="activity-content">
            <view class="activity-top">
              <t-tag theme="{{activity.isPinned ? 'success' : 'default'}}" variant="light">{{activity.category}}</t-tag>
              <text class="activity-date">{{activity.dateTime}}</text>
            </view>
            <view class="activity-title">{{activity.title}}</view>
            <view class="body">{{activity.summary}}</view>
            <view class="activity-place">{{activity.place}}</view>
          </view>
        </view>
      </block>
    </block>
  </view>
</view>
