.home-page {
  padding-bottom: 56rpx;
}

.home-hero {
  border-radius: 28rpx;
  background: linear-gradient(145deg, #e1ead6, #f7f1e4);
  padding: 46rpx 36rpx;
}

.hero-copy {
  margin: 22rpx 0 30rpx;
}

.sync-note {
  margin-top: 24rpx;
  color: #7b8675;
  font-size: 24rpx;
  text-align: center;
}

.book-grid {
  display: grid;
  gap: 28rpx;
  margin-top: 32rpx;
}

.book-card {
  display: flex;
  min-height: 300rpx;
  overflow: hidden;
}

.book-cover {
  flex-shrink: 0;
  width: 220rpx;
  min-height: 300rpx;
  background: #dfe7d3;
}

.book-content {
  display: flex;
  flex: 1;
  flex-direction: column;
  padding: 28rpx;
}

.book-author {
  color: #6d7e63;
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.book-title {
  margin-top: 14rpx;
  color: #314d37;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.5;
}

.book-summary {
  margin-top: 14rpx;
  font-size: 25rpx;
}

.book-link {
  margin-top: auto;
  padding-top: 18rpx;
  color: #587a5b;
  font-size: 25rpx;
  font-weight: 600;
}
