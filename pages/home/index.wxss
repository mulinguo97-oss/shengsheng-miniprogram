.home-page {
  padding: 0 0 48rpx;
}

.home-poster {
  display: block;
  width: 100%;
  height: 25vh;
}

.activity-feed {
  padding: 28rpx;
}

.activity-card {
  overflow: hidden;
  margin-top: 24rpx;
}

.activity-card:first-child {
  margin-top: 0;
}

.activity-cover {
  display: block;
  width: 100%;
  height: 280rpx;
  background: #e5ead8;
}

.activity-content {
  padding: 28rpx;
}

.activity-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.activity-date,
.activity-place {
  color: #7b8675;
  font-size: 24rpx;
}

.activity-title {
  margin-top: 18rpx;
  color: #314d37;
  font-size: 32rpx;
  font-weight: 700;
}

.activity-place {
  margin-top: 18rpx;
}

.state-text {
  margin-top: 28rpx;
}

.error-text {
  color: #9b4a3a;
}
