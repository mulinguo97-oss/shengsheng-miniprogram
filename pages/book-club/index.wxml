<view class="page book-page">
  <view class="eyebrow">两本书 · 两个分区</view>
  <view class="title">生生读书会</view>
  <view class="body intro">书籍介绍可公开查看；音频、视频和原书仅向管理员已报名授权的客户开放。</view>

  <view wx:if="{{loading}}" class="state-text">正在同步书籍信息...</view>
  <view wx:elif="{{errorMessage}}" class="state-text">{{errorMessage}}</view>

  <view class="section book-list">
    <block wx:for="{{books}}" wx:key="id" wx:for-item="book">
      <view class="book-card card">
        <image class="book-cover" src="{{book.coverUrl}}" mode="aspectFill" />
        <view class="book-copy">
          <view class="author-line">{{book.author.name}} · 著</view>
          <view class="book-title">《{{book.title}}》</view>
          <view class="body summary">{{book.summary}}</view>
          <view class="resource-chips">
            <text>听音频</text>
            <text>看视频</text>
            <text>看原书</text>
          </view>
          <t-button theme="primary" shape="round" block data-id="{{book.id}}" bindtap="goDetail">进入书籍分区</t-button>
        </view>
      </view>
    </block>
  </view>
</view>
