.intro {
  margin-top: 20rpx;
}

.state-text {
  margin-top: 24rpx;
  color: #7b8675;
  font-size: 24rpx;
}

.book-list {
  display: grid;
  gap: 30rpx;
}

.book-card {
  overflow: hidden;
}

.book-cover {
  display: block;
  width: 100%;
  height: 330rpx;
  background: #dfe7d3;
}

.book-copy {
  padding: 32rpx;
}

.author-line {
  color: #6d7e63;
  font-size: 25rpx;
  letter-spacing: 2rpx;
}

.book-title {
  margin-top: 14rpx;
  color: #314d37;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.5;
}

.summary {
  margin-top: 18rpx;
}

.resource-chips {
  display: flex;
  gap: 14rpx;
  margin: 24rpx 0;
}

.resource-chips text {
  border-radius: 999rpx;
  background: #e5ead8;
  padding: 8rpx 18rpx;
  color: #4f714d;
  font-size: 23rpx;
}
