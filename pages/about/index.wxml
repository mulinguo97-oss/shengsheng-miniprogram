<view class="page profile-page">
  <view class="profile-hero card">
    <image wx:if="{{user}}" class="profile-avatar" src="{{avatarSrc}}" mode="aspectFill" />
    <view class="profile-hero-copy">
      <view class="eyebrow">我的学习</view>
      <view class="title">{{user ? user.name : '登录后查看已开通书籍'}}</view>
      <view class="body hero-note">{{user ? '查看管理员为你开通的书籍、通知和个人资料。' : '书籍内容采用管理员报名授权，不提供公开自助报名。'}}</view>
    </view>
    <t-button wx:if="{{user}}" theme="default" variant="outline" shape="round" size="small" bindtap="logout">退出</t-button>
  </view>

  <view wx:if="{{loading}}" class="body state-text">正在读取我的学习...</view>

  <block wx:elif="{{!user}}">
    <view class="section card login-card">
      <view class="section-title">账号登录</view>
      <view class="body">请使用网站账号登录。登录后仍需管理员为对应书籍开通权限。</view>
      <t-input label="邮箱" placeholder="请输入登录邮箱" value="{{loginEmail}}" bind:change="onLoginEmailChange" />
      <t-input label="密码" placeholder="请输入密码" type="password" value="{{loginPassword}}" bind:change="onLoginPasswordChange" />
      <t-button theme="primary" shape="round" block loading="{{loggingIn}}" disabled="{{loggingIn}}" bindtap="login">登录</t-button>
    </view>
  </block>

  <block wx:else>
    <view class="section card login-card" wx:if="{{mustChangePassword}}">
      <view class="section-title">首次登录设置新密码</view>
      <view class="body">为保护账号安全，请设置至少10位且同时包含字母和数字的新密码。</view>
      <t-input label="新密码" placeholder="请输入新密码" type="password" value="{{newPassword}}" bind:change="onNewPasswordChange" />
      <t-input label="确认密码" placeholder="请再次输入新密码" type="password" value="{{confirmPassword}}" bind:change="onConfirmPasswordChange" />
      <t-button theme="primary" shape="round" block loading="{{saving}}" disabled="{{saving}}" bindtap="changePassword">保存新密码</t-button>
    </view>

    <block wx:if="{{!mustChangePassword}}">
    <view class="section card my-books-card">
      <view class="section-head">
        <view class="section-title">我的书籍</view>
        <t-button theme="default" variant="outline" size="small" shape="round" bindtap="loadMyBooks">刷新</t-button>
      </view>
      <view wx:if="{{loadingBooks}}" class="body empty-text">正在读取已开通书籍...</view>
      <view wx:elif="{{booksMessage}}" class="body empty-text">{{booksMessage}}</view>
      <block wx:else>
        <block wx:for="{{myBooks}}" wx:key="id" wx:for-item="book">
          <view class="my-book-item" data-id="{{book.id}}" bindtap="goBookDetail">
            <image class="my-book-cover" src="{{book.coverUrl}}" mode="aspectFill" />
            <view class="my-book-copy">
              <view class="my-book-title">《{{book.title}}》</view>
              <view class="my-book-author">{{book.author.name}} · {{book.access.message}}</view>
              <view class="my-book-link">继续学习 →</view>
            </view>
          </view>
        </block>
      </block>
    </view>

    <view class="section card profile-form">
      <view class="section-title">基础信息</view>
      <t-input label="姓名" value="{{formName}}" placeholder="请输入姓名" bind:change="onNameChange" />
      <t-input label="邮箱" value="{{user.email}}" disabled />
      <t-input label="手机号" value="{{formPhone}}" placeholder="请输入手机号" type="number" bind:change="onPhoneChange" />
      <t-input label="城市" value="{{formCity}}" placeholder="如：深圳" bind:change="onCityChange" />
      <t-input label="阅读兴趣" value="{{formInterests}}" placeholder="经典、哲学、传统文化" bind:change="onInterestsChange" />
      <t-textarea label="简介" value="{{formBio}}" placeholder="写下你的阅读目标" bind:change="onBioChange" />
      <t-button theme="primary" shape="round" block loading="{{saving}}" disabled="{{saving}}" bindtap="save">保存资料</t-button>
    </view>

    <view class="section card notice-card">
      <view class="section-head">
        <view class="section-title">我的通知</view>
        <t-button theme="default" variant="outline" size="small" shape="round" bindtap="loadProfile">刷新</t-button>
      </view>
      <view wx:if="{{!profile.messages.length}}" class="body empty-text">暂无服务器通知。</view>
      <block wx:else>
        <block wx:for="{{profile.messages}}" wx:key="id" wx:for-item="message">
          <view class="message-item {{message.readAt ? '' : 'message-unread'}}">
            <view class="message-title">{{message.subject}}</view>
            <view class="body message-body">{{message.body}}</view>
            <view class="message-meta">{{message.createdAt}}</view>
            <t-button wx:if="{{!message.readAt}}" data-id="{{message.id}}" size="small" variant="outline" shape="round" bindtap="markMessageRead">标为已读</t-button>
          </view>
        </block>
      </block>
    </view>
    </block>
  </block>
</view>
