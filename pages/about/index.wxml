<view class="page profile-page">
  <view class="profile-hero card">
    <image wx:if="{{user}}" class="profile-avatar" src="{{avatarSrc}}" mode="aspectFill" />
    <view>
      <view class="eyebrow">个人中心</view>
      <view class="title">{{user ? user.name : '登录后查看个人中心'}}</view>
      <view class="body hero-note">{{user ? '资料、通知和报名记录已同步服务器。' : '使用网页登录账号登录后同步个人资料、通知和报名记录。'}}</view>
    </view>
    <t-button wx:if="{{user}}" theme="default" variant="outline" shape="round" size="small" bindtap="logout">退出</t-button>
  </view>

  <view wx:if="{{loading}}" class="body state-text">正在读取个人中心...</view>

  <block wx:elif="{{!user}}">
    <view class="section card login-card">
      <view class="section-title">账号登录</view>
      <t-input label="邮箱" placeholder="请输入网页登录邮箱" value="{{loginEmail}}" bind:change="onLoginEmailChange" />
      <t-input label="密码" placeholder="请输入密码" type="password" value="{{loginPassword}}" bind:change="onLoginPasswordChange" />
      <t-button theme="primary" shape="round" block loading="{{loggingIn}}" disabled="{{loggingIn}}" bindtap="login">登录个人中心</t-button>
    </view>
  </block>

  <block wx:else>
    <view class="section stats-grid">
      <view class="stat-card card">
        <view class="stat-number">{{profile.stats.participatedCount}}</view>
        <view class="stat-label">已参与</view>
      </view>
      <view class="stat-card card">
        <view class="stat-number">{{profile.stats.upcomingCount}}</view>
        <view class="stat-label">待参加</view>
      </view>
      <view class="stat-card card">
        <view class="stat-number">{{profile.stats.joinedDays}}</view>
        <view class="stat-label">加入天数</view>
      </view>
      <view class="stat-card card">
        <view class="stat-number">{{profile.stats.unreadCount}}</view>
        <view class="stat-label">未读通知</view>
      </view>
    </view>

    <view class="section card profile-form">
      <view class="section-title">基础信息</view>
      <t-input label="姓名" value="{{formName}}" placeholder="请输入姓名" bind:change="onNameChange" />
      <t-input label="邮箱" value="{{user.email}}" disabled />
      <t-input label="手机号" value="{{formPhone}}" placeholder="请输入手机号" type="number" bind:change="onPhoneChange" />
      <t-input label="城市" value="{{formCity}}" placeholder="如：深圳" bind:change="onCityChange" />
      <t-input label="兴趣" value="{{formInterests}}" placeholder="传统文化、共读、亲子活动" bind:change="onInterestsChange" />
      <t-textarea label="简介" value="{{formBio}}" placeholder="写下你的文化陪伴目标" bind:change="onBioChange" />
      <t-button theme="primary" shape="round" block loading="{{saving}}" disabled="{{saving}}" bindtap="save">保存资料</t-button>
    </view>

    <view class="section card">
      <view class="section-head">
        <view class="section-title">我的通知</view>
        <t-button theme="default" variant="outline" size="small" shape="round" bindtap="loadProfile">刷新</t-button>
      </view>
      <view wx:if="{{!profile.messages.length}}" class="body empty-text">暂无服务器通知。</view>
      <block wx:else>
        <block wx:for="{{profile.messages}}" wx:key="id" wx:for-item="message">
          <view class="message-item {{message.readAt ? '' : 'message-unread'}}">
            <view class="message-title">{{message.subject}}</view>
            <view class="body message-body">{{message.body}}</view>
            <view class="message-meta">{{message.createdAt}}</view>
            <t-button wx:if="{{!message.readAt}}" data-id="{{message.id}}" size="small" variant="outline" shape="round" bindtap="markMessageRead">标为已读</t-button>
          </view>
        </block>
      </block>
    </view>

    <view class="section card">
      <view class="section-title">报名记录</view>
      <view wx:if="{{!profile.participations.length}}" class="body empty-text">暂无服务器报名记录。</view>
      <block wx:else>
        <block wx:for="{{profile.participations}}" wx:key="id" wx:for-item="item">
          <view class="participation-item">
            <view class="participation-top">
              <view class="participation-title">{{item.title}}</view>
              <view class="status-pill">{{item.status}}</view>
            </view>
            <view class="body participation-detail">{{item.subtitle}}</view>
            <view class="participation-meta">{{item.date}} {{item.time}} · {{item.place}} · {{item.participantCount}} 人</view>
          </view>
        </block>
      </block>
    </view>

    <view class="section">
      <t-button theme="primary" variant="outline" shape="round" block bindtap="goAssistant">咨询生生助手</t-button>
    </view>
  </block>
</view>
