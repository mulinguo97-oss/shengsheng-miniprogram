<view class="page detail-page" wx:if="{{course}}">
  <view class="eyebrow">生生读书会</view>
  <view class="title">{{course.bookTitle}}</view>
  <view class="detail-meta">主讲：{{course.lecturer}} · {{course.nextSessionDate}} {{course.nextSessionTime}}</view>

  <view class="section card content">
    <view class="body">{{course.summary}}</view>
    <view class="body paragraph">地点：{{course.place}}</view>
    <view class="body paragraph">说明：{{course.notes}}</view>
    <view class="body paragraph">当前关注：{{course.participantCount}} / {{course.capacity}} 人</view>
  </view>

  <view class="section card form-card">
    <view class="form-title">报名意向</view>
    <t-input label="姓名" placeholder="请输入姓名" value="{{name}}" bind:change="onNameChange" />
    <t-input label="手机号" placeholder="请输入手机号" value="{{phone}}" type="number" bind:change="onPhoneChange" />
    <t-input label="人数" placeholder="报名人数" value="{{participantCount}}" type="number" bind:change="onCountChange" />
    <t-textarea label="备注" placeholder="可填写孩子年龄、同行情况或关注问题" value="{{note}}" bind:change="onNoteChange" />
    <t-button theme="primary" shape="round" block bindtap="submitSignup">提交报名意向</t-button>
  </view>
</view>
